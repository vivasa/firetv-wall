<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer shadow for depth -->
    <item
        android:bottom="-4dp"
        android:left="-4dp"
        android:right="-4dp"
        android:top="-4dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="8dp"
                android:color="#30000000" />
            <corners android:radius="6dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Mid shadow -->
    <item
        android:bottom="-2dp"
        android:left="-2dp"
        android:right="-2dp"
        android:top="-2dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="3dp"
                android:color="#40000000" />
            <corners android:radius="5dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Warm gold frame border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#C9A96E" />
            <corners android:radius="4dp" />
        </shape>
    </item>

    <!-- Inner dark matting -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#1A1A1A" />
            <corners android:radius="2dp" />
        </shape>
    </item>

</layer-list>
