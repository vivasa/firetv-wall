<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="520dp"
    android:layout_height="match_parent"
    android:layout_gravity="center"
    android:layout_marginTop="40dp"
    android:layout_marginBottom="40dp"
    android:scrollbars="none"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/settings_card_bg"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/primary_text"
            android:textSize="22sp"
            android:fontFamily="monospace"
            android:textAllCaps="true"
            android:letterSpacing="0.15"
            android:layout_marginBottom="28dp" />

        <!-- 0. Theme -->
        <LinearLayout
            android:id="@+id/settingTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_theme"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueTheme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Classic"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 1. Primary Timezone -->
        <LinearLayout
            android:id="@+id/settingPrimaryTz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_primary_timezone"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valuePrimaryTz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="US Eastern (New York)"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 2. Secondary Timezone -->
        <LinearLayout
            android:id="@+id/settingSecondaryTz"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_secondary_timezone"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueSecondaryTz"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="India (Kolkata)"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 3. Time Format -->
        <LinearLayout
            android:id="@+id/settingTimeFormat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_time_format"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueTimeFormat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12-hour"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 4. Chime -->
        <LinearLayout
            android:id="@+id/settingChime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_chime"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueChime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 5. Wallpaper Rotation -->
        <LinearLayout
            android:id="@+id/settingWallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_wallpaper_rotation"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueWallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 6. Wallpaper Interval -->
        <LinearLayout
            android:id="@+id/settingWallpaperInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_wallpaper_interval"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueWallpaperInterval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 min"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 7. Burn-in Drift -->
        <LinearLayout
            android:id="@+id/settingDrift"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_burnin_drift"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueDrift"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 8. Night Dim -->
        <LinearLayout
            android:id="@+id/settingNightDim"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_night_dim"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueNightDim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 9. Active Preset -->
        <LinearLayout
            android:id="@+id/settingActivePreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active Playlist"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueActivePreset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="None"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 10. Player Size -->
        <LinearLayout
            android:id="@+id/settingPlayerSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginBottom="8dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_player_size"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valuePlayerSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medium"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- 11. Show Player -->
        <LinearLayout
            android:id="@+id/settingShowPlayer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:focusable="true"
            android:focusableInTouchMode="true">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/label_show_player"
                android:textColor="@color/primary_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/valueShowPlayer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ON"
                android:textColor="@color/accent"
                android:textSize="13sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- QR Code / Companion URL -->
        <LinearLayout
            android:id="@+id/settingCompanionUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/settings_item_bg"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Configure from your phone"
                android:textColor="@color/primary_text"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <ImageView
                android:id="@+id/qrCodeImage"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center_horizontal"
                android:background="#FFFFFFFF"
                android:padding="4dp"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/companionUrlText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="monospace"
                android:textColor="@color/accent"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
