<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="56dp"
    android:background="@color/mantle_surface_elevated"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="4dp">

    <ImageView
        android:id="@+id/miniArtwork"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:contentDescription="Playlist artwork"
        tools:background="@color/mantle_accent" />

    <TextView
        android:id="@+id/miniTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="@style/TextAppearance.Mantle.Body"
        tools:text="Jazz Standards" />

    <ImageButton
        android:id="@+id/miniPlayPause"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Play or pause"
        android:src="@drawable/ic_play"
        app:tint="@color/mantle_on_surface"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

</LinearLayout>
