<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_lg"
    android:paddingTop="@dimen/spacing_sm"
    android:paddingEnd="@dimen/spacing_xs"
    android:paddingBottom="@dimen/spacing_sm">

    <ImageView
        android:id="@+id/rowArtwork"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="Playlist artwork"
        android:scaleType="centerCrop"
        tools:background="@color/mantle_accent" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rowName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Mantle.Body"
            tools:text="Jazz Standards" />

        <TextView
            android:id="@+id/rowSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Mantle.Caption"
            android:visibility="gone"
            tools:text="Now playing: Track Name"
            tools:visibility="visible" />
    </LinearLayout>

    <View
        android:id="@+id/rowActiveBar"
        android:layout_width="3dp"
        android:layout_height="32dp"
        android:layout_marginStart="@dimen/spacing_sm"
        android:background="@color/mantle_accent"
        android:visibility="gone"
        tools:visibility="visible" />

    <ImageButton
        android:id="@+id/rowOverflow"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="More options"
        android:src="@drawable/ic_more_vert"
        app:tint="@color/mantle_on_surface_muted" />

</LinearLayout>
